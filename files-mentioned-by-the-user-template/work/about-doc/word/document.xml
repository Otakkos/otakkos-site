 w:val="both"/></w:pPr><w:r w:rsidRPr="005C1200"><w:t xml:space="preserve">L’aventure </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="005C1200"><w:t>O'Takkos</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="005C1200"><w:t xml:space="preserve"> commence en 2018 sous l'impulsion de son fondateur, Joseph Raoul </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="005C1200"><w:t>Eric</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="005C1200"><w:t xml:space="preserve">. Face à l'engouement mondial pour le "French Tacos", une ambition claire est née : importer ce concept ultra-gourmand en Côte d'Ivoire tout en l'adaptant à la générosité et à la culture ivoirienne. Pionnier du tacos français à Abidjan, </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="005C1200"><w:t>O'Takkos</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="005C1200"><w:t xml:space="preserve"> a su s'imposer comme la référence incontournable de la restauration rapide locale.</w:t></w:r></w:p><w:p w14:paraId="0EB8F4CF" w14:textId="77777777" w:rsidR="005C1200" w:rsidRPr="005C1200" w:rsidRDefault="005C1200" w:rsidP="00CD5FAF"><w:pPr><w:jc w:val="both"/><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="005C1200"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Le Concept </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="005C1200"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>O'Takkos</w:t></w:r><w:proofErr w:type="spellEnd"/></w:p><w:p w14:paraId="689464B1" w14:textId="19D28D2D" w:rsidR="005C1200" w:rsidRDefault="005C1200" w:rsidP="00CD5FAF"><w:pPr><w:jc w:val="both"/></w:pPr><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="005C1200"><w:t>O'Takkos</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="005C1200"><w:t xml:space="preserve">, c'est l'art de revisiter </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="005C1200"><w:t>le tacos</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="005C1200"><w:t>. Rien à voir avec la recette mexicaine traditionnelle ! Nos tacos se composent d'une galette de blé tendre, garnie selon vos envies de viandes rigoureusement sélectionnées, de frites croustillantes, et surtout, de notre fameuse sauce fromagère onctueuse. Le tout est ensuite soigneusement plié puis toasté à la presse pour un rendu unique et savoureux.</w:t></w:r></w:p><w:p w14:paraId="0E172723" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="00CD5FAF" w:rsidRDefault="00CD5FAF" w:rsidP="00CD5FAF"><w:pPr><w:jc w:val="both"/></w:pPr><w:r w:rsidRPr="00CD5FAF"><w:t>L'enseigne compte plusieurs succursales à Abidjan :</w:t></w:r></w:p><w:p w14:paraId="29452596" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="00CD5FAF" w:rsidRDefault="00CD5FAF" w:rsidP="00CD5FAF"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:jc w:val="both"/></w:pPr><w:r w:rsidRPr="00CD5FAF"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Angré</w:t></w:r></w:p><w:p w14:paraId="5CBFA3FD" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="00CD5FAF" w:rsidRDefault="00CD5FAF" w:rsidP="00CD5FAF"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:jc w:val="both"/></w:pPr><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00CD5FAF"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Faya</w:t></w:r><w:proofErr w:type="spellEnd"/></w:p><w:p w14:paraId="3F02F91A" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="00CD5FAF" w:rsidRDefault="00CD5FAF" w:rsidP="00CD5FAF"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:jc w:val="both"/></w:pPr><w:r w:rsidRPr="00CD5FAF"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Zone 4</w:t></w:r></w:p><w:p w14:paraId="701B2C44" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="00CD5FAF" w:rsidRDefault="00CD5FAF" w:rsidP="00CD5FAF"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:jc w:val="both"/></w:pPr><w:r w:rsidRPr="00CD5FAF"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Yopougon</w:t></w:r></w:p><w:p w14:paraId="5D7E1407" w14:textId="77777777" w:rsidR="00CD5FAF" w:rsidRPr="0